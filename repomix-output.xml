  }) =>
      ShiftDefinition(
        id: id ?? this.id,
        name: name ?? this.name,
        startTime: startTime ?? this.startTime,
        endTime: endTime ?? this.endTime,
        colorHex: colorHex ?? this.colorHex,
        elderId: elderId ?? this.elderId,
        createdBy: createdBy ?? this.createdBy,
        assignments: assignments ?? this.assignments,
