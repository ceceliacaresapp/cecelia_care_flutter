                        const SizedBox(height: 4),
                        Text(
                          '${_l10n.calendarEventTypePrefix} ${event.eventType}',
                          style: _theme.textTheme.bodyMedium?.copyWith(
                              fontWeight: FontWeight.w500),
                        ),
                      ],
