                                fontWeight: FontWeight.w700)),
                        const SizedBox(height: 2),
                        Row(
                          children: [
                            Icon(t.statusIcon,
                                size: 12, color: t.statusColor),
                            const SizedBox(width: 3),
                            Text(t.statusLabel,
                                style: TextStyle(
                                    fontSize: 11,
                                    fontWeight: FontWeight.w600,
                                    color: t.statusColor)),
                            if (dueLabel != null) ...[
                              const SizedBox(width: 8),
                              Icon(Icons.schedule,
                                  size: 12,
                                  color: t.isOverdue
                                      ? AppTheme.dangerColor
                                      : AppTheme.textSecondary),
                              const SizedBox(width: 3),
                              Text(dueLabel,
