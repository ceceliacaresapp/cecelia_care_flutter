  @override
  Widget build(BuildContext context) {
    return Column(
      crossAxisAlignment: CrossAxisAlignment.start,
      children: [
        Row(
          children: [
            const Icon(Icons.collections_outlined, color: _kImageColor, size: 16),
            const SizedBox(width: 6),
            const Text(
              'UPLOADED IMAGES',
              style: TextStyle(
                fontSize: 11,
                fontWeight: FontWeight.w600,
                letterSpacing: 0.8,
                color: _kImageColor,
              ),
            ),
            const Spacer(),
            TextButton.icon(
