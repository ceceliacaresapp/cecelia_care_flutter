                              ),
                              maxLines: 3,
                              overflow: TextOverflow.ellipsis,
                            ),
                            // Image thumbnail — shown inline on image entries
                            if (type == EntryType.image) ...[  
                              const SizedBox(height: 8),
                              _ImageThumbnail(
                                imageUrl: data?['url'] as String? ?? '',
