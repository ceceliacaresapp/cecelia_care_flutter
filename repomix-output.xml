rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // -----------------------------------------------------------------------
    // Elder images — uploaded by caregivers from ImageUploadScreen.
    // Path pattern: elder_images/{elderId}/{folderId}/{fileName}
    //
    // Any authenticated user can read (caregivers viewing shared images).
    // Any authenticated user can write (upload) files up to 10 MB.
    // -----------------------------------------------------------------------
    match /elder_images/{elderId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024;
    }

    // -----------------------------------------------------------------------
    // Wound photos — uploaded from WoundTrackingScreen.
    // Path pattern: wound_photos/{elderId}/{bodyRegion}/{fileName}
    // -----------------------------------------------------------------------
    match /wound_photos/{elderId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024;
    }

    // -----------------------------------------------------------------------
    // Medication photos — uploaded from MedicationManagerScreen.
    // Path pattern: medication_photos/{elderId}/{medDefId}/{fileName}
    // -----------------------------------------------------------------------
    match /medication_photos/{elderId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024;
    }

    // -----------------------------------------------------------------------
    // Elder documents — uploaded from DocumentVaultScreen.
    // Path pattern: elder_documents/{elderId}/{category}/{fileName}
    // -----------------------------------------------------------------------
    match /elder_documents/{elderId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024;
    }

    // -----------------------------------------------------------------------
    // Profile photos — uploaded from elder profile edit or user account.
    // Path pattern: profile_photos/{userId}/{fileName}
    //
    // Anyone authenticated can read (profile photos are displayed app-wide).
    // Only the owning user can write/delete their own photos.
    // -----------------------------------------------------------------------
    match /profile_photos/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 5 * 1024 * 1024;
    }

    // -----------------------------------------------------------------------
    // Default deny — anything not matched above is blocked.
    // -----------------------------------------------------------------------
  }
}
