      ),
      floatingActionButton: _buildFab(context, activeElder),
      body: TabBarView(
        controller: _tabController,
        children: [
          _MedicationLogTab(l10n: _l10n, theme: _theme),
          _RemindersTab(activeElder: activeElder),
        ],
