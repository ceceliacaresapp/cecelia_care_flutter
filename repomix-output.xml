                          thickness: 1,
                          color: _kExpenseColor.withOpacity(0.15)),
                      ...userSummary.expenses.map((exp) => Padding(
                            padding: const EdgeInsets.symmetric(
                                vertical: 6),
                            child: Row(
                              crossAxisAlignment:
                                  CrossAxisAlignment.start,
                              children: [
                                Expanded(
                                  child: Column(
                                    crossAxisAlignment:
                                        CrossAxisAlignment.start,
                                    children: [
                                      Text(exp.description,
                                          style: theme.textTheme
