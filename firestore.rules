rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    // Checks if the user is listed in the 'caregiverUserIds' array of the elderProfile
    function isCaregiver(elderId) {
      // Safe check: prevents crashes if elderId is null (e.g., personal caregiver journals)
      return elderId != null && 
             request.auth != null &&
             exists(/databases/$(database)/documents/elderProfiles/$(elderId)) &&
             request.auth.uid in get(/databases/$(database)/documents/elderProfiles/$(elderId)).data.caregiverUserIds;
    }

    // --- NEW: Role-based helpers ---
    // Returns the role string for the current user on this elder.
    // Primary admin → "admin". In caregiverRoles map → that value.
    // In caregiverUserIds but not in map → "caregiver" (backwards-compat).
    function roleOf(elderId) {
      let data = get(/databases/$(database)/documents/elderProfiles/$(elderId)).data;
      let roles = data.get('caregiverRoles', {});
      return data.primaryAdminUserId == request.auth.uid
        ? 'admin'
        : roles.get(request.auth.uid, 'caregiver');
    }

    // True for admin only (profile management, med definitions, etc.)
    function isAdminRole(elderId) {
      return isCaregiver(elderId) && roleOf(elderId) == 'admin';
    }

    // True for admin or caregiver — excludes viewer (viewer is read-only)
    function canWrite(elderId) {
      return isCaregiver(elderId) &&
        (roleOf(elderId) == 'admin' || roleOf(elderId) == 'caregiver');
    }
    // --- END NEW ---

    // --- Website-specific Collections ---
    match /waitlist/{entry} {
      allow create: if true;
      allow read, update, delete: if false;
    }

    // --- Family Invite Codes ---
    // Top-level collection where doc id == the code string. A code
    // carries a denormalized elderName + role + creator so a signed-in
    // user can preview an invite before committing. Writes are owned
    // exclusively by Cloud Functions (createInviteCode / redeemInviteCode
    // / revokeInviteCode), which enforce role + TTL + use-count rules
    // that are too complex to express in Firestore rules.
    match /inviteCodes/{code} {
      // Any signed-in user can read a single code by id (for preview
      // + redemption). Documents contain only non-sensitive metadata
      // (elder name + role + expiry) — no PHI.
      allow get: if request.auth != null;
      // List queries are restricted per-document to the code creator.
      // If a query returns a doc the caller didn't create, the query
      // is rejected. This lets the admin "my recent invites" view
      // work without exposing other caregivers' invites.
      allow list: if request.auth != null &&
        resource.data.createdByUid == request.auth.uid;
      // All mutations go through Cloud Functions (Admin SDK bypasses
      // rules); block direct client writes.
      allow create, update, delete: if false;
    }
    match /suggestions/{suggestionId} {
      allow create: if true;
      allow read, update, delete: if false;
    }

    // --- Users Collection ---
    // ADDED: any signed-in user can read other users' profiles so that
    // getAssociatedUsersForElder() can resolve display names for caregiver
    // lists, messaging, and the timeline "Logged by" field.
    // Write remains restricted to the document owner only.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
      
      match /{document=**} {
         allow read: if request.auth != null;
         allow write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // --- Elder Profiles (Metadata) ---
    match /elderProfiles/{elderId} {
      // Safely covers both 'get' and 'list' as long as the Flutter query uses arrayContains
      allow read: if request.auth != null && request.auth.uid in resource.data.caregiverUserIds;
      allow create: if request.auth != null;
      allow update: if request.auth != null && request.auth.uid == resource.data.primaryAdminUserId; 
      allow delete: if request.auth != null && request.auth.uid == resource.data.primaryAdminUserId;
      
      match /medications/{medId} {
        allow read: if isCaregiver(elderId);
        // NEW: caregiver and admin can write (mark taken/skipped); viewer cannot
        allow write: if canWrite(elderId);
      }

      // ADDED: Image folders — all members can read, admin only can create/delete.
      // Deleting a folder does NOT delete images; they become unfiled.
      match /imageFolders/{folderId} {
        allow read: if isCaregiver(elderId);
        allow create, delete: if isAdminRole(elderId);
        allow update: if false;
      }

      // Custom entry types — all caregivers can read, admin can manage.
      match /customEntryTypes/{entryTypeId} {
        allow read: if isCaregiver(elderId);
        allow write: if canWrite(elderId);
      }

      // Shift definitions — all caregivers can read, admin can manage.
      match /shiftDefinitions/{shiftId} {
        allow read: if isCaregiver(elderId);
        allow write: if canWrite(elderId);
      }

      // Vault documents — all caregivers can read, admin can manage.
      match /vaultDocuments/{docId} {
        allow read: if isCaregiver(elderId);
        allow write: if canWrite(elderId);
      }

      // Wound entries — all caregivers can read and write.
      match /woundEntries/{entryId} {
        allow read: if isCaregiver(elderId);
        allow write: if canWrite(elderId);
      }

      // ADL assessments — all caregivers can read, caregivers+ can write.
      match /adlAssessments/{assessmentId} {
        allow read: if isCaregiver(elderId);
        allow write: if canWrite(elderId);
      }

      // Category budgets — all caregivers can read, admin can manage.
      match /categoryBudgets/{yearMonth} {
        allow read: if isCaregiver(elderId);
        allow write: if canWrite(elderId);
      }

      // Behavioral entries — all caregivers can read and write.
      match /behavioralEntries/{entryId} {
        allow read: if isCaregiver(elderId);
        allow write: if canWrite(elderId);
      }

      // Music reactions — per-song reaction log driving the "what
      // calms / what agitates" analytics. All caregivers can read
      // and write (viewer sees history, cannot add).
      match /musicReactions/{entryId} {
        allow read: if isCaregiver(elderId);
        allow write: if canWrite(elderId);
      }

      // Incident reports — regulatory-grade documentation for falls,
      // elopements, medication errors, behavioral events. Caregivers
      // read + write; viewers read-only. Timestamped for audit.
      match /incidentReports/{reportId} {
        allow read: if isCaregiver(elderId);
        allow write: if canWrite(elderId);
      }

      // Wandering assessments — all caregivers can read and write.
      match /wanderingAssessments/{assessmentId} {
        allow read: if isCaregiver(elderId);
        allow write: if canWrite(elderId);
      }

      // Fall risk assessments (CDC STEADI) — all caregivers can read and write.
      match /fallRiskAssessments/{assessmentId} {
        allow read: if isCaregiver(elderId);
        allow write: if canWrite(elderId);
      }

      // Skin assessments — all caregivers can read and write.
      match /skinAssessments/{assessmentId} {
        allow read: if isCaregiver(elderId);
        allow write: if canWrite(elderId);
      }

      // Turning/repositioning logs — all caregivers can read and write.
      match /turningLogs/{logId} {
        allow read: if isCaregiver(elderId);
        allow write: if canWrite(elderId);
      }

      // Discharge checklists — any caregiver can read/write.
      match /dischargeChecklists/{checklistId} {
        allow read: if isCaregiver(elderId);
        allow write: if canWrite(elderId);
      }

      // Cognitive assessments — any caregiver can read/write.
      match /cognitiveAssessments/{assessmentId} {
        allow read: if isCaregiver(elderId);
        allow write: if canWrite(elderId);
      }

      // Succession plan ("If I Can't Be Here") — one plan per elder at
      // doc id "primary". Any caregiver can read so a backup can pull it
      // up in an emergency. Write restricted to admin/caregiver (not viewer).
      match /successionPlan/{planId} {
        allow read: if isCaregiver(elderId);
        allow write: if canWrite(elderId);
      }

      // Taper schedules — prescriber-authored step-down plans for
      // medications that must not be stopped abruptly. Caregivers read
      // (so anyone on the team can see today's dose); admin/caregiver
      // write. Viewers cannot author tapers.
      match /taperSchedules/{taperId} {
        allow read: if isCaregiver(elderId);
        allow write: if canWrite(elderId);
      }

      // Care tasks — delegation hub. Any caregiver can read/create/update.
      // Delete restricted to admin or task creator.
      match /careTasks/{taskId} {
        allow read: if isCaregiver(elderId);
        allow create: if canWrite(elderId);
        allow update: if canWrite(elderId);
        allow delete: if isAdminRole(elderId) ||
          (canWrite(elderId) && resource.data.createdBy == request.auth.uid);
      }
    }

    // --- Elders Data (Timeline, Days, Meals) ---
    match /elders/{elderId} {
       allow read, write: if isCaregiver(elderId);
       
       match /{document=**} {
          allow read, write: if isCaregiver(elderId);
       }
    }

    // --- Medication Definitions ---
    // NEW: read still open to any caregiver (needed for reminder display).
    // Write now restricted to admin only — caregiver cannot add/edit/delete
    // prescription records.
    match /medicationDefinitions/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && isAdminRole(request.resource.data.elderId);
      allow update, delete: if request.auth != null && isAdminRole(resource.data.elderId);
    }

    // --- Respite Providers (shared, read-only for most users) ---
    match /respiteProviders/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    // --- Support Groups (community-contributed, read by all
    // authenticated users, additions open to any signed-in user;
    // no client-side edit/delete to keep the directory stable).
    match /supportGroups/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    // --- Collection Groups & Shared Collections ---

    // Journal Entries (Standalone collection)
    match /journalEntries/{entryId} {
      allow read: if request.auth != null;
      
      // NEW: create now also requires canWrite() — viewer role is blocked from logging.
      // Existing caregiver and admin flows are unaffected.
      allow create: if request.auth != null && (
        canWrite(request.resource.data.elderId) || 
        (request.resource.data.elderId == null && request.resource.data.loggedByUserId == request.auth.uid)
      );
      allow update: if request.auth != null && (
        isCaregiver(resource.data.elderId) || 
        (resource.data.elderId == null && resource.data.loggedByUserId == request.auth.uid)
      );
      allow delete: if request.auth != null && (
        isCaregiver(resource.data.elderId) || 
        (resource.data.elderId == null && resource.data.loggedByUserId == request.auth.uid)
      );
    }

    // Calendar Events
    match /calendarEvents/{eventId} {
      allow read: if request.auth != null;
      allow create: if isCaregiver(request.resource.data.elderId);
      allow update, delete: if isCaregiver(resource.data.elderId);
    }
    
    // Health Reminders
    match /healthReminders/{reminderId} {
      allow read: if request.auth != null;
      allow create: if isCaregiver(request.resource.data.elderId);
      allow update, delete: if isCaregiver(resource.data.elderId);
    }

    // Financial Data — restricted to the owning user.
    match /budget_entries/{docId} {
      allow read: if request.auth != null &&
        resource.data.userId == request.auth.uid;
      allow create: if request.auth != null &&
        request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null &&
        resource.data.userId == request.auth.uid;
    }
    match /income_entries/{docId} {
      allow read: if request.auth != null &&
        resource.data.userId == request.auth.uid;
      allow create: if request.auth != null &&
        request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null &&
        resource.data.userId == request.auth.uid;
    }
    match /financial_assets/{docId} {
      allow read: if request.auth != null &&
        resource.data.userId == request.auth.uid;
      allow create: if request.auth != null &&
        request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null &&
        resource.data.userId == request.auth.uid;
    }
    match /financial_liabilities/{docId} {
      allow read: if request.auth != null &&
        resource.data.userId == request.auth.uid;
      allow create: if request.auth != null &&
        request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null &&
        resource.data.userId == request.auth.uid;
    }

    // --- Insurance Policies ---
    // Richer, shareable insurance records. Owner-only — mirrors the
    // financial-data pattern. Benefit counters live as a subcollection
    // of the parent policy.
    match /insurancePolicies/{docId} {
      allow read: if request.auth != null &&
        resource.data.userId == request.auth.uid;
      allow create: if request.auth != null &&
        request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null &&
        resource.data.userId == request.auth.uid;

      match /benefitCounters/{counterId} {
        // Benefit counters are owned implicitly by the parent policy's
        // owner. We can't do a get() on the parent in rules without
        // paying for extra reads on every query, so we duplicate a
        // userId field in the counter doc and enforce it here.
        allow read, write: if request.auth != null &&
          request.resource.data.userId == request.auth.uid ||
          (resource != null && resource.data.userId == request.auth.uid);
      }
    }

    // --- Insurance Claims ---
    match /insuranceClaims/{docId} {
      allow read: if request.auth != null &&
        resource.data.userId == request.auth.uid;
      allow create: if request.auth != null &&
        request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null &&
        resource.data.userId == request.auth.uid;
    }

    // --- Collection Group Queries ---
    match /{path=**}/expenses/{expenseId} {
      allow read, write: if request.auth != null;
    }
    match /{path=**}/expense/{expenseId} {
      allow read, write: if request.auth != null;
    }

    // --- Caregiver Journal (private, author-only) ---
    // ADDED: Personal journal entries written by a caregiver for themselves.
    // Completely separate from the main journalEntries collection —
    // never appears on the timeline. Only the author can read or write.
    match /caregiverJournalEntries/{entryId} {
      allow read, delete: if request.auth != null &&
        resource.data.userId == request.auth.uid;
      allow create: if request.auth != null &&
        request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null &&
        resource.data.userId == request.auth.uid;
    }

    // -----------------------------------------------------------------------
    // Wellness & Gamification Collections (Self-Care module)
    //
    // These are per-user private collections — each user can only read/write
    // their own data. No cross-user access needed.
    // -----------------------------------------------------------------------

    // Wellness check-ins — daily 5-dimension self-assessments.
    // Queried with: where('userId', isEqualTo: uid)
    match /wellnessCheckins/{docId} {
      allow read: if request.auth != null &&
        resource.data.userId == request.auth.uid;
      allow create: if request.auth != null &&
        request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null &&
        resource.data.userId == request.auth.uid;
    }

    // Zarit Burden Interview (ZBI-12) assessments — monthly clinical
    // burden score. Private to the caregiver who took it. Queried
    // with: where('userId', isEqualTo: uid) orderBy completedAt desc.
    match /zaritAssessments/{docId} {
      allow read: if request.auth != null &&
        resource.data.userId == request.auth.uid;
      allow create: if request.auth != null &&
        request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null &&
        resource.data.userId == request.auth.uid;
    }

    // Caregiver points — one doc per user, doc ID == userId.
    // Tracks total points, level, streaks, streak freeze.
    match /caregiverPoints/{userId} {
      allow read, write: if request.auth != null &&
        request.auth.uid == userId;
    }

    // Weekly challenge progress — one doc per user per week.
    // Doc ID pattern: {userId}_{weekStart}
    // Has a userId field for query filtering.
    match /challengeProgress/{docId} {
      allow read: if request.auth != null &&
        resource.data.userId == request.auth.uid;
      allow create: if request.auth != null &&
        request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null &&
        resource.data.userId == request.auth.uid;
    }
  }
}
