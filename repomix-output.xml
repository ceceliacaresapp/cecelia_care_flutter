            children: [
              Text(category, style: const TextStyle(fontWeight: FontWeight.w500)),
              Text('\$${spent.toStringAsFixed(0)} / \$${total.toStringAsFixed(0)}', style: const TextStyle(color: Colors.black54)),
            ],
          ),
          const SizedBox(height: 4),
